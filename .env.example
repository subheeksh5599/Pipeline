# Arc testnet RPC — set by ARC CLI, override if needed
ARC_RPC_URL=http://localhost:8545

# Deployed PipelinePolicy contract address
POLICY_ADDRESS=

# Deployer private key — keep this secret, never commit a real key
PRIVATE_KEY=

# Dashboard → Engine connection
NEXT_PUBLIC_ENGINE_URL=http://localhost:3100

# Agent addresses to track on the dashboard overview
NEXT_PUBLIC_WATCHED_AGENTS=

# Etherscan-compatible explorer API key for contract verification
ARC_ETHERSCAN_KEY=
